# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.*
!.env.example

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# IDE/editor settings
.vscode/
.idea/

# Logs and local databases
*.log
*.sqlite
*.db

# Chainlit runtime artifacts
.chainlit/*
!.chainlit/config.toml
!.chainlit/translations/
!.chainlit/translations/*.json
.chainlit/cache/
.chainlit/tmp/

# OS files
.DS_Store

# Ignore specific files
.files/